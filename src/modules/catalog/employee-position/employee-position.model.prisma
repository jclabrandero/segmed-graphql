
model EmployeePosition {
	id			Int		@id @default(autoincrement())
	name		String	@unique
	description	String?

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	employees		Clerk[]

	creatorUser		User	@relation(name: "EmployeePositionCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "EmployeePositionLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}
