
model User {
	id			Int		@id @default(autoincrement())
	userName	String	@unique
	displayName	String?
	email		String?
	directory	String	@default("LOCAL") // LOCAL, AD,

	status		Int		@default(1)

	groups		UserGroup[]
	passwords	UserPassword[]
	clerkUser	ClerkUser?

	createdGroups			Group[]				@relation(name: "GroupCreatorUser")
	updatedGroups			Group[]				@relation(name: "GroupLastUpdateUser")
	createdGroupPermissions	GroupPermission[]	@relation(name: "GroupPermissionCreatorUser")
	updatedGroupPermissions	GroupPermission[]	@relation(name: "GroupPermissionLastUpdateUser")

	createdPersonDocumentTypes	PersonDocumentType[]	@relation(name: "PersonDocumentTypeCreatorUser")
	updatedPersonDocumentTypes	PersonDocumentType[]	@relation(name: "PersonDocumentTypeLastUpdateUser")
	createdEmployeeTypes		EmployeeType[]			@relation(name: "EmployeeTypeCreatorUser")
	updatedEmployeeTypes		EmployeeType[]			@relation(name: "EmployeeTypeLastUpdateUser")
	createdEmployeePositions	EmployeePosition[]		@relation(name: "EmployeePositionCreatorUser")
	updatedEmployeePositions	EmployeePosition[]		@relation(name: "EmployeePositionLastUpdateUser")
	createdInsuredTypes			InsuredType[]			@relation(name: "InsuredTypeCreatorUser")
	updatedInsuredTypes			InsuredType[]			@relation(name: "InsuredTypeLastUpdateUser")
	createdMedicalSubspecialties			MedicalSubspecialty[]			@relation(name: "MedicalSubspecialtyCreatorUser")
	updatedMedicalSubspecialties			MedicalSubspecialty[]			@relation(name: "MedicalSubspecialtyLastUpdateUser")
	createdMedicalSpecialties				MedicalSpecialty[]				@relation(name: "MedicalSpecialtyCreatorUser")
	updatedMedicalSpecialties				MedicalSpecialty[]				@relation(name: "MedicalSpecialtyLastUpdateUser")
	createdMedicalSpecialtySubspecialties	MedicalSpecialtySubspecialty[]	@relation(name: "MedicalSpecialtySubspecialtyCreatorUser")
	updatedMedicalSpecialtySubspecialties	MedicalSpecialtySubspecialty[]	@relation(name: "MedicalSpecialtySubspecialtyLastUpdateUser")
	createdMedicalGroups					MedicalGroup[]					@relation(name: "MedicalGroupCreatorUser")
	updatedMedicalGroupes					MedicalGroup[]					@relation(name: "MedicalGroupLastUpdateUser")
	createdMedicalGroupSpecialties			MedicalGroupSpecialty[]			@relation(name: "MedicalGroupSpecialtyCreatorUser")
	updatedMedicalGroupSpecialties			MedicalGroupSpecialty[]			@relation(name: "MedicalGroupSpecialtyLastUpdateUser")

	createdBelongings	Belonging[]	@relation(name: "BelongingCreatorUser")
	updatedBelongings	Belonging[]	@relation(name: "BelongingLastUpdateUser")
	createdMedicalOffices	MedicalOffice[]	@relation(name: "MedicalOfficeCreatorUser")
	updatedMedicalOffices	MedicalOffice[]	@relation(name: "MedicalOfficeLastUpdateUser")

	createdPersons	Person[]	@relation(name: "PersonCreatorUser")
	updatedPersons	Person[]	@relation(name: "PersonLastUpdateUser")
	createdClerks				Clerk[]					@relation(name: "ClerkCreatorUser")
	updatedClerks				Clerk[]					@relation(name: "ClerkLastUpdateUser")
	createdClerkUsers			ClerkUser[]				@relation(name: "ClerkUserCreatorUser")
	updatedClerkUsers			ClerkUser[]				@relation(name: "ClerkUserLastUpdateUser")
	createdClerkMedicalOffices	ClerkMedicalOffice[]	@relation(name: "ClerkMedicalOfficeCreatorUser")
	updatedClerkMedicalOffices	ClerkMedicalOffice[]	@relation(name: "ClerkMedicalOfficeLastUpdateUser")
	createdInsureds				Insured[]				@relation(name: "InsuredCreatorUser")
	updatedInsureds				Insured[]				@relation(name: "InsuredLastUpdateUser")
}


model UserGroup {
	id		Int		@unique @default(autoincrement())
	status	Int		@default(1)

	userId	Int
	groupId	Int

	user	User	@relation(fields: [userId], references: [id])
	group	Group	@relation(fields: [groupId], references: [id])

	@@id([ userId, groupId ])
}

model UserPassword {
	id			Int		@unique @default(autoincrement())
	encrypted	String
	status		Int		@default(1)

	userName	String

	user		User	@relation(fields: [userName], references: [userName])

	@@id([ userName, encrypted ])
}
