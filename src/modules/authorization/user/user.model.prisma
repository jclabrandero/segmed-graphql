
model User {
	id			Int		@id @default(autoincrement())
	userName	String	@unique
	displayName	String?
	email		String?
	directory	String	@default("LOCAL") // LOCAL, AD,

	status		Int		@default(1)

	groups		UserGroup[]
	passwords	UserPassword[]

	createdPersonDocumentTypes	PersonDocumentType[]	@relation(name: "PersonDocumentTypeCreatorUser")
	updatedPersonDocumentTypes	PersonDocumentType[]	@relation(name: "PersonDocumentTypeLastUpdateUser")
	deletedPersonDocumentTypes	PersonDocumentType[]	@relation(name: "PersonDocumentTypeDeletionUser")

	createdEmployeeTypes	EmployeeType[]	@relation(name: "EmployeeTypeCreatorUser")
	updatedEmployeeTypes	EmployeeType[]	@relation(name: "EmployeeTypeLastUpdateUser")
	deletedEmployeeTypes	EmployeeType[]	@relation(name: "EmployeeTypeDeletionUser")

	createdEmployeePositions	EmployeePosition[]	@relation(name: "EmployeePositionCreatorUser")
	updatedEmployeePositions	EmployeePosition[]	@relation(name: "EmployeePositionLastUpdateUser")
	deletedEmployeePositions	EmployeePosition[]	@relation(name: "EmployeePositionDeletionUser")

	createdPersons	Person[]	@relation(name: "PersonCreatorUser")
	updatedPersons	Person[]	@relation(name: "PersonLastUpdateUser")
	deletedPersons	Person[]	@relation(name: "PersonDeletionUser")
}


model UserGroup {
	id		Int		@unique @default(autoincrement())
	status	Int		@default(1)

	userId	Int
	groupId	Int

	user	User	@relation(fields: [userId], references: [id])
	group	Group	@relation(fields: [groupId], references: [id])

	@@id([ userId, groupId ])
}

model UserPassword {
	id			Int		@unique @default(autoincrement())
	encrypted	String
	status		Int		@default(1)

	userName	String

	user		User	@relation(fields: [userName], references: [userName])

	@@id([ userName, encrypted ])
}
