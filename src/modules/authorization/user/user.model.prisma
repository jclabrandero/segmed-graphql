	createdInterclinicalMedicalGroup			InterclinicalMedicalGroup[]			@relation(name: "InterclinicalMedicalGroupCreatorUser")
	updatedInterclinicalMedicalGroup			InterclinicalMedicalGroup[]			@relation(name: "InterclinicalMedicalGroupLastUpdateUser")
	createdInterclinicalMedicalSpecialties		InterclinicalMedicalSpecialty[]		@relation(name: "InterclinicalMedicalSpecialtyCreatorUser")
	updatedInterclinicalMedicalSpecialties		InterclinicalMedicalSpecialty[]		@relation(name: "InterclinicalMedicalSpecialtyLastUpdateUser")
	createdInterclinicalMedicalSubspecialties	InterclinicalMedicalSubspecialty[]	@relation(name: "InterclinicalMedicalSubspecialtyCreatorUser")
	updatedInterclinicalMedicalSubspecialties	InterclinicalMedicalSubspecialty[]	@relation(name: "InterclinicalMedicalSubspecialtyLastUpdateUser")
	createdInterclinicalFileUploads				InterclinicalFileUpload[]			@relation(name: "InterclinicalFileUploadCreatorUser")
	updatedInterclinicalFileUploads				InterclinicalFileUpload[]			@relation(name: "InterclinicalFileUploadLastUpdateUser")
	createdPrescriptions			Prescription[]			@relation(name: "PrescriptionCreatorUser")
	updatedPrescriptions			Prescription[]			@relation(name: "PrescriptionLastUpdateUser")
	createdPrescriptionExterns		PrescriptionExtern[]	@relation(name: "PrescriptionExternCreatorUser")
