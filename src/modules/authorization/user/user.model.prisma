model UserGroup {
	id		Int		@unique @default(autoincrement())
	
	userId	Int
	groupId	Int

	status	Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	user	User	@relation(fields: [userId], references: [id])
	group	Group	@relation(fields: [groupId], references: [id])

	creatorUser		User	@relation(name: "UserGroupCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "UserGroupLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)

	@@id([ userId, groupId ])
}

model UserPassword {
	id			Int		@unique @default(autoincrement())
	encrypted	String
	status		Int		@default(1)

	userName	String

	user		User	@relation(fields: [userName], references: [userName])

	@@id([ userName, encrypted ])
}
