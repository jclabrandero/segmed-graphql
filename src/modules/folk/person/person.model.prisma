
model Person {
	id			Int			@id @default(autoincrement())
	firstName	String
	lastName	String
	sex			String
	birthDate	DateTime

	documentNumber			String?
	personDocumentTypeId	Int?

	status					Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	personDocumentType		PersonDocumentType? @relation(fields: [personDocumentTypeId], references: [id])

	creatorUser		User	@relation(name: "PersonCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "PersonLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}
