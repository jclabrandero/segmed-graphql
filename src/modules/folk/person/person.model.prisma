
model Person {
	id			Int			@id @default(autoincrement())
	firstName	String
	lastName	String
	sex			String
	birthDate	DateTime

	documentNumber			String?
	personDocumentTypeId	Int?

	status					Int		@default(1)

	personDocumentType		PersonDocumentType? @relation(fields: [personDocumentTypeId], references: [id])
}
