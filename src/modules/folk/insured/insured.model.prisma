
model Insured {
	id			Int			@id @default(autoincrement())
	code		String		@unique
	iin			Int?		//Insured Identification Number
	inletDate	DateTime
	outletDate	DateTime?
	tradeUnion	Boolean
	address		String?
	phone		String?

	holderInsuredId	Int?
	personId		Int		@unique
	insuredTypeId	Int
	belongingId		Int

	status			Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	holderInsured		Insured?	@relation(name: "HolderInsured", fields: [holderInsuredId], references: [id], onDelete: NoAction, onUpdate: NoAction)
	dependents			Insured[]	@relation(name: "HolderInsured")
	person				Person		@relation(fields: [personId], references: [id])
	insuredType			InsuredType	@relation(fields: [insuredTypeId], references: [id])
	belonging			Belonging	@relation(fields: [belongingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
	clinicCareInsured	ClinicCareInsured[]

	creatorUser		User		@relation(name: "InsuredCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?		@relation(name: "InsuredLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}
