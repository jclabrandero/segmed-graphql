
model Inventory {
	id		Int	@id @default(autoincrement())
	stock	Int	@default(0)
	price	Decimal @default(0)
	min		Int @default(0)

	pharmacyId		Int
	medicationId	Int

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	pharmacy	Pharmacy	@relation(fields: [pharmacyId], references: [id])
	medication	Medication	@relation(fields: [medicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

	creatorUser		User	@relation(name: "InventoryCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "InventoryLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)

	@@unique([ pharmacyId, medicationId ])
}

model Arrival {
	id			Int		@id @default(autoincrement())
	remark		String
	arrivalDate	DateTime
	invoiceNumber				Int?
	invoiceAuthorizationCode	String?
	invoiceControlCode			String?
	invoiceTotalRefPrice		Decimal @default(0)

	approvalState		Int		@default(0)
	approvalDate		DateTime?
	approvalUserName	String?

	closed				Boolean	@default(false)

	pharmacyId	Int
	providerId	Int?

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?
	
	pharmacy	Pharmacy	@relation(fields: [pharmacyId], references: [id])
	provider	Provider?	@relation(fields: [providerId], references: [id])
	items		ArrivalItem[]

	creatorUser		User	@relation(name: "ArrivalCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "ArrivalLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}

model ArrivalItem {
	id			Int		@id @default(autoincrement())
	quantity	Int
	price		Decimal

	arrivalId	Int
	batchId		Int

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	arrival		Arrival		@relation(fields: [arrivalId], references: [id])
	batch		Batch		@relation(fields: [batchId], references: [id])

	creatorUser		User	@relation(name: "ArrivalItemCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "ArrivalItemLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}

model Departure {
	id				Int		@id @default(autoincrement())
	remark			String
	departureDate	DateTime

	pharmacyId	Int

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	pharmacy	Pharmacy	@relation(fields: [pharmacyId], references: [id])
	items		DepartureItem[]

	creatorUser		User	@relation(name: "DepartureCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "DepartureLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}

model DepartureItem {
	id			Int		@id @default(autoincrement())
	quantity	Int
	price		Decimal

	departureId	Int
	batchId		Int

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	departure	Departure	@relation(fields: [departureId], references: [id])
	batch		Batch		@relation(fields: [batchId], references: [id])

	creatorUser		User	@relation(name: "DepartureItemCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "DepartureItemLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}
