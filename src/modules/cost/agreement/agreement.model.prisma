model Agreement {
  id          Int    @id @default(autoincrement())
  name        String
  validFrom   DateTime
  validTo     DateTime?

  providerId    Int
  fileUploadId  Int @unique

  status      Int    @default(1)

  creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?
 
  provider    Provider    @relation(fields: [providerId], references: [id])
  file				FileUpload  @relation(fields: [fileUploadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
	
  creatorUser     User	@relation(name: "AgreementCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser  User?	@relation(name: "AgreementLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}
