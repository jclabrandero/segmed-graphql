
model FileUpload {
	id			Int		@id @default(autoincrement())
	md5			String	@unique

	name		String
	encoding	String
	type		String
	extension	String

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	interclinicals	InterclinicalFileUpload[]
	agreement				Agreement?

	creatorUser			User	@relation(name: "FileUploadCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "FileUploadLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
}
