
model Prescription {
	id			Int		@unique @default(autoincrement())
	quantity	Int
	indications	String

	medicationId	Int
	pharmacyId		Int
	clinicCareId	Int

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	medication	Medication	@relation(fields: [medicationId], references: [id])
	pharmacy	Pharmacy	@relation(fields: [pharmacyId], references: [id])
	clinicCare	ClinicCare	@relation(fields: [clinicCareId], references: [id])

	creatorUser		User	@relation(name: "PrescriptionCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "PrescriptionLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)

	@@id([ medicationId, pharmacyId, clinicCareId ])
}

model PrescriptionExtern {
	id			Int		@unique @default(autoincrement())
	quantity	Int
	indications	String

	medicationId	Int
	clinicCareId	Int

	status		Int		@default(1)

	creatorUserName		String
	creationDate		DateTime
	lastUpdateUserName	String?
	lastUpdateDate		DateTime?

	medication	Medication	@relation(fields: [medicationId], references: [id])
	clinicCare	ClinicCare	@relation(fields: [clinicCareId], references: [id])

	creatorUser		User	@relation(name: "PrescriptionExternCreatorUser", fields: [creatorUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)
	lastUpdateUser	User?	@relation(name: "PrescriptionExternLastUpdateUser", fields: [lastUpdateUserName], references: [userName], onDelete: NoAction, onUpdate: NoAction)

	@@id([ medicationId, clinicCareId ])
}
